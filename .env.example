# Copie para .env.local e preencha com os valores do projeto Supabase
# (Dashboard > Settings > API / Settings > Database)

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Connection string do pooler (Settings > Database > Connection pooling), modo transaction, porta 6543
# Usada em runtime pela app (Drizzle client, prepare:false)
DATABASE_URL=

# Connection string direta (porta 5432), usada só pelo Drizzle Kit para gerar/aplicar migrations
DIRECT_URL=
